// =====================================
// ATTENDANCE RECORDS
// =====================================

let attendanceRecords = [];


// =====================================
// QR SCAN FUNCTION
// =====================================

function scanQRCode() {

    let scannedQR =
        document.getElementById("scanner")
        .value
        .trim()
        .replace(/\s+/g, "")
        .toUpperCase();

    // PREVENT EMPTY SCAN
    if (!scannedQR) return;

    console.log("Scanned QR:", scannedQR);

    // FIND STUDENT
    let student =
        students.find(
            s =>
                s.qrCode
                .replace(/\s+/g, "")
                .toUpperCase() === scannedQR
        );

    // =====================================
    // IF STUDENT FOUND
    // =====================================

    if (student) {

        let currentTime =
            new Date().toLocaleString();

        // STUDENT IMAGE
        document.getElementById("studentImage").src =
            student.image;

        // STUDENT INFO
        document.getElementById("studentName").textContent =
            student.name;

        document.getElementById("studentSR").textContent =
            student.srCode;

        document.getElementById("studentCourse").textContent =
            student.course;

        document.getElementById("studentTime").textContent =
            currentTime;

        // =====================================
        // ATTENDANCE LOGIC
        // =====================================

        let existingRecord =
            attendanceRecords.find(
                record =>
                    record.srCode === student.srCode
            );

// =====================================
// TIME IN / TIME OUT SYSTEM
// =====================================

// FIRST SCAN = TIME IN
if (!existingRecord) {

    attendanceRecords.push({

        name: student.name,
        srCode: student.srCode,
        course: student.course,

        timeIn: currentTime,
        timeOut: "---",

        status: "Time In"

    });


}

// SECOND SCAN = TIME OUT
else if (existingRecord.timeOut === "---") {

    existingRecord.timeOut =
        currentTime;

    existingRecord.status =
        "Completed";


}

// THIRD SCAN = ALREADY FINISHED
else {


}

        // UPDATE TABLE
        updateAttendanceTable();

        // CLEAR INPUT
        document.getElementById("scanner").value = "";

        // REFOCUS
        focusScanner();

    }

    // =====================================
    // IF QR NOT FOUND
    // =====================================

    else {

        alert("QR Code Not Recognized");

        document.getElementById("scanner").value = "";

        focusScanner();
    }
}


// =====================================
// UPDATE ATTENDANCE TABLE
// =====================================

function updateAttendanceTable() {

    let table =
        document.getElementById("attendanceTable");

    // CLEAR TABLE
    table.innerHTML = "";

    // LOOP RECORDS
    attendanceRecords.forEach(record => {

        let row = table.insertRow();

        row.insertCell(0).innerHTML =
            record.name;

        row.insertCell(1).innerHTML =
            record.srCode;

        row.insertCell(2).innerHTML =
            record.course;

        row.insertCell(3).innerHTML =
            record.timeIn;

        row.insertCell(4).innerHTML =
            record.timeOut;

        row.insertCell(5).innerHTML =
            record.status;

    });
}


// =====================================
// SCANNER EVENTS
// =====================================

let scanner =
    document.getElementById("scanner");

// QR scanners usually press ENTER automatically
scanner.addEventListener("keydown", function (event) {

    if (event.key === "Enter") {

        event.preventDefault();

        scanQRCode();
    }
});


// =====================================
// AUTO FOCUS FUNCTION
// =====================================

function focusScanner() {

    setTimeout(() => {

        document.getElementById("scanner").focus();

    }, 100);
}


// =====================================
// AUTO FOCUS WHEN PAGE LOADS
// =====================================

window.onload = function () {

    focusScanner();

};
