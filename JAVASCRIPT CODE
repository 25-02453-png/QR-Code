// =====================================
// LOGIN FUNCTION
// =====================================

function login() {

    let email =
        document.getElementById("email").value.trim();

    let password =
        document.getElementById("password").value.trim();

    // EMAIL FORMAT
    let emailFormat =
        /^\d{2}-\d{5}@g\.batstate-u\.edu\.ph$/;

    // PASSWORD FORMAT
    let passwordFormat =
        /^\d{2}-\d{5}$/;

    // VALIDATE EMAIL
    if (!emailFormat.test(email)) {

        return;
    }

    // VALIDATE PASSWORD
    if (!passwordFormat.test(password)) {

        return;
    }


    // HIDE LOGIN
    document.getElementById("loginCard").style.display =
        "none";

    // SHOW DASHBOARD
    document.getElementById("dashboard").style.display =
        "block";

    // AUTO FOCUS QR INPUT
    focusScanner();
}


